<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootOverview"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/screen_padding"
        android:paddingTop="@dimen/screen_padding_vertical"
        android:paddingBottom="@dimen/screen_padding_vertical">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/card_margin"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="@dimen/hero_radius"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/main"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hero_badge"
                    android:textColor="@color/hero_badge_text"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/step_overview_title"
                    android:textColor="@color/hero_text"
                    android:textSize="@dimen/hero_title_size"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/step_overview_body"
                    android:textColor="@color/hero_subtext"
                    android:textSize="@dimen/hero_body_size" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/card_margin"
            style="@style/Widget.IncheonAI.Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_overview_title"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/section_title_size"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/overviewHeadlineText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/content_spacing_large"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/headline_text_size"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/overviewBodyText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/content_spacing_medium"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/body_text_size" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/content_spacing_xlarge"
                    android:text="@string/section_actions_title"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/section_title_size"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/form_field_spacing"
                    app:cardBackgroundColor="@color/button_tint_light"
                    app:cardCornerRadius="@dimen/card_radius"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/panel_padding">

                        <TextView
                            android:id="@+id/actionOneText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/body_text_size" />

                        <TextView
                            android:id="@+id/actionTwoText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/content_spacing_small"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/body_text_size" />

                        <TextView
                            android:id="@+id/actionThreeText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/content_spacing_small"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/body_text_size" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/previousButton"
                style="@style/Widget.IncheonAI.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_marginEnd="@dimen/button_gap"
                android:layout_weight="1"
                android:text="@string/action_previous" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/restartButton"
                style="@style/Widget.IncheonAI.Button.Primary"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_weight="1"
                android:text="@string/action_restart" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
