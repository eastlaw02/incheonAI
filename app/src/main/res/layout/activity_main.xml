<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootFlight"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/screen_padding"
        android:paddingTop="@dimen/screen_padding_vertical"
        android:paddingBottom="@dimen/screen_padding_vertical">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/card_margin"
            app:cardBackgroundColor="@android:color/transparent"
            android:backgroundTint="@android:color/transparent"
            app:strokeWidth="0dp"
            app:cardCornerRadius="@dimen/hero_radius"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/main"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hero_badge"
                    android:textColor="@color/hero_badge_text"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/step_flight_title"
                    android:textColor="@color/hero_text"
                    android:textSize="@dimen/hero_title_size"
                    android:fontFamily="@font/pretendard_bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/step_flight_body"
                    android:textColor="@color/hero_subtext"
                    android:textSize="@dimen/hero_body_size" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/card_margin"
            style="@style/Widget.IncheonAI.Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_booking_title"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/section_title_size"
                    android:fontFamily="@font/pretendard_bold" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.IncheonAI.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/form_field_spacing"
                    android:hint="@string/hint_airline">

                    <com.google.android.material.textfield.TextInputEditText
                        style="@style/Widget.IncheonAI.TextField"
                        android:id="@+id/airlineInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>


                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.IncheonAI.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/form_field_spacing"
                    android:hint="@string/hint_flight_number">

                    <com.google.android.material.textfield.TextInputEditText
                        style="@style/Widget.IncheonAI.TextField"
                        android:id="@+id/flightNumberInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>


                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.IncheonAI.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/form_field_spacing"
                    android:hint="@string/hint_route">

                    <com.google.android.material.textfield.TextInputEditText
                        style="@style/Widget.IncheonAI.TextField"
                        android:id="@+id/routeInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>


                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.IncheonAI.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/form_field_spacing"
                    android:hint="@string/hint_departure_window">

                    <com.google.android.material.textfield.TextInputEditText
                        style="@style/Widget.IncheonAI.TextField"
                        android:id="@+id/departureInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_spacing_large"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/nextButton"
                style="@style/Widget.IncheonAI.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="@string/action_next" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
